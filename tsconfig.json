{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "zite-endpoints-sdk": ["src/mocks/zite-endpoints-sdk.ts"],
      "zite-file-upload-sdk": ["src/mocks/zite-file-upload-sdk.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/api"]
}
